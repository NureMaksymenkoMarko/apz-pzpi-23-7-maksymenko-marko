interface SkincareApi {
    @POST("api/login")
    suspend fun login(@Body request: LoginRequest): Response<LoginResponse>

    @GET("api/users/me")
    suspend fun getCurrentUser(): Response<User>

    @GET("api/skin/{skinId}/analyses")
    suspend fun getAnalysesBySkin(@Path("skinId") skinId: Int): Response<List<Analysis>>
}
Фрагмент структури моделей даних
data class Skin(
    val id: Int,
    val type: String,
    val description: String?,
    @SerializedName("user_id") val userId: Int
)

data class Analysis(
    val id: Int,
    @SerializedName("analysis_type") val analysisType: String,
    val result: String?,
    @SerializedName("skin_id") val skinId: Int?
)



